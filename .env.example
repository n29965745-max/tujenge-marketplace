# ─────────────────────────────────────────────────────────────────────
# TUJENGE — Environment Variables
# Copy this file to `.env.local` and fill in real values.
# NEVER commit real `.env.local` to git.
# ─────────────────────────────────────────────────────────────────────

# ── Supabase (https://supabase.com) ────────────────────────────────
# Find these in your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY

# Service role key — SERVER ONLY, never expose to the client.
# Used for admin operations like webhooks and cron jobs.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# ── Site ───────────────────────────────────────────────────────────
# Used in auth callback emails and absolute URLs.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Optional ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_VERSION=1.0.0
